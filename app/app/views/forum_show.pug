extends layout

block content
  nav.pill-nav
    a.logo(href="/") RecipeSwap
    a(href="/") Home
    a(href="/recipes") Recipes
    a(href="/tags") Categories
    a(href="/reviews") Reviews
    a.active(href="/forum") Forum
    a(href="/leaderboard") Leaderboard 

    if isAdmin
      a.primary(href="/admin") Admin
      a(href="/users") Users
      a(href="/allswaps") All Swaps

    if loggedIn
      a(href="/matches") Matches
      span.nav-spacer
      a(href="/profile") Profile
      a(href="/swaps") My Swaps
      a(href="/logout") Logout
    else
      span.nav-spacer
      a.logonbtn(href="/signin") Sign in
      a.logonbtn.primary(href="/signup") Sign up

  h1= post.title
  p= post.content
  p Posted by #{post.username}

  if isAdmin
    form(method="POST", action=`/admin/forum/posts/${post.post_id}/delete`)
      button(type="submit") Delete post

  h2 Comments

  each c in comments
    .comment-card
      p
        strong= c.username
        |  - Upvotes: #{c.upvotes}
      p= c.comment

      if loggedIn
        form(method="POST", action=`/forum/comments/${c.comment_id}/upvote`)
          button(type="submit") Upvote

      if isAdmin
        form(method="POST", action=`/admin/forum/comments/${c.comment_id}/delete`)
          button(type="submit") Delete comment

  if loggedIn
    form(method="POST", action=`/forum/${post.post_id}/comments`)
      textarea(name="comment", required)
      button(type="submit") Add comment