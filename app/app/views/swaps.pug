extends layout

block content
  nav.pill-nav 
    a.logo(href="/") RecipeSwap
    a(href="/") Home
    a(href="/recipes") Recipes
    a(href="/tags") Categories
    a(href="/reviews") Reviews
    a(href="/forum") Forum
    a(href="/leaderboard") Leaderboard 
    if isAdmin
      a.primary Admin
      a(href="/users") Users  
      a.active(href="/allswaps") All Swaps
    if loggedIn
      span.nav-spacer
      a(href="/matches") Matches
      a(href="/profile") Profile
      a(href="/swaps") My Swaps
      a(href="/logout") Logout
    else  
      span.nav-spacer
      a.logonbtn(href="/signin") Sign in
      a.logonbtn.primary(href="/signup") Sign up

  h1 Recipe Swaps

  if swaps.length
    each swap in swaps
      div.card
        p Swap ID: #{swap.swap_id}
        p Requested: #{swap.requested_title}
        p Offered: #{swap.offered_title}
        p Status: #{swap.swap_status}
        p Requested by: #{swap.username}
        hr
  else
    p No swaps yet.
    

    