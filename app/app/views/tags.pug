extends layout

block content
  body
   nav.pill-nav 
    a.logo(href="/") RecipeSwap
    a(href="/") Home
    a(href="/recipes") Recipes
    a.active(href="/tags") Categories 
    a(href="/reviews") Reviews
    a(href="/forum") Forum
    a(href="/leaderboard") Leaderboard 
    if isAdmin
      a.primary Admin
      a(href="/users") Users
      a(href="/allswaps") All Swaps
    if loggedIn
      span.nav-spacer
      a(href="/matches") Matches
      a(href="/profile") Profile
      a(href="/swaps") My Swaps
      a(href="/logout") Logout
    else  
      span.nav-spacer
      a.logonbtn(href="/signin") Sign in
      a.logonbtn.primary(href="/signup") Sign up
    
    
  h2.page-title Recipes tagged: #{tag_name}

  if recipes && recipes.length
    .card-grid
      each recipe in recipes
        .card
          h3= recipe.recipe_title
          p= recipe.summary
          a.btn(href=`/recipes/${recipe.recipe_id}`) View Recipe
  else
    p No recipes found for this tag.