extends layout

block content
  nav.pill-nav  
    a.logo(href="/") RecipeSwap
    a(href="/") Home
   
    a(href="/recipes") Recipes
    a.active(href="/tags") Categories
    a(href="/reviews") Reviews
    
    if isAdmin
      a.primary Admin
      a(href="/users") Users
      a(href="/allswaps") All Swaps
    if loggedIn
      span.nav-spacer
      a(href="/profile") Profile
      a(href="/swaps") My Swaps
      a(href="/logout") Logout
    else  
      span.nav-spacer
      a.logonbtn(href="/signin") Sign in
      a.logonbtn.primary(href="/signup") Sign up
     
  h2.page-title Categories

  if tags && tags.length
    .tag-list
      each tag in tags
        
          a.btnflex(href=`/tags/${tag.tag_id}`)= tag.tag_name
  else
    p No categories found.