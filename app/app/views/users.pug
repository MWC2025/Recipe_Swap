extends layout 
block content
  nav.pill-nav 
     a.logo(href="/") RecipeSwap
     a(href="/") Home
     a(href="/recipes") Recipes
     a(href="/tags") Categories 
     a(href="/reviews") Reviews
     if isAdmin
      a.primary Admin
      a.active(href="/users") Users
      a(href="/allswaps") All Swaps
     if loggedIn
      span.nav-spacer
      a(href="/profile") Profile
      a(href="/swaps") My Swaps
      a(href="/logout") Logout
     else  
      span.nav-spacer
      a.logonbtn(href="/signin") Sign in
      a.logonbtn.primary(href="/signup") Sign up

  h2.page-title Users

  .card-grid
    each user in users
      .card
        h3= user.username
        p= user.email_address
        a.btn(href=`/users/${user.user_id}`) View Profile