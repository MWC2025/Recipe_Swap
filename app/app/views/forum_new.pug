extends layout

block content
  nav.pill-nav
    a.logo(href="/") RecipeSwap
    a(href="/") Home
    a(href="/recipes") Recipes
    a(href="/tags") Categories
    a(href="/reviews") Reviews
    a.active(href="/forum") Forum
    a(href="/leaderboard") Leaderboard 

    if isAdmin
      a.primary(href="/admin") Admin
      a(href="/users") Users
      a(href="/allswaps") All Swaps

    if loggedIn
      a(href="/matches") Matches
      span.nav-spacer
      a(href="/profile") Profile
      a(href="/swaps") My Swaps
      a(href="/logout") Logout
    else
      span.nav-spacer
      a.logonbtn(href="/signin") Sign in
      a.logonbtn.primary(href="/signup") Sign up

  h1 New Forum Post

  form(method="POST", action="/forum")
    input(type="text", name="title", placeholder="Post title", required)
    input(type="text", name="ingredient_tag", placeholder="Ingredient tag")
    textarea(name="content", required)
    button(type="submit") Create post