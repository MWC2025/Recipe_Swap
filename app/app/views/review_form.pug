extends layout

block content
  nav.pill-nav 
    a.logo(href="/") RecipeSwap
    a(href="/") Home
    a(href="/users") Users
    a(href="/recipes") Recipes
    a(href="/tags") Categories
    a.active(href="/reviews") Reviews

  h1 Leave a Review
  p Recipe: #{targetRecipe.recipe_title}

  form(method="POST", action="/recipes/" + targetRecipe.recipe_id + "/reviews")
    label(for="rating") Rating
    select(name="rating", id="rating", required)
      option(value="") Select a rating
      option(value="1") 1
      option(value="2") 2
      option(value="3") 3
      option(value="4") 4
      option(value="5") 5

    br
    br

    label(for="comment") Comment
    textarea(name="comment", id="comment", rows="5", cols="40", required)

    br
    br

    button(type="submit") Submit Review