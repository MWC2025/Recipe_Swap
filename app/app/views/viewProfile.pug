extends layout
block content
  nav.pill-nav  
    a.logo(href="/") RecipeSwap
    a(href="/") Home
    a(href="/recipes") Recipes
    a(href="/tags") Categories
    a(href="/reviews") Reviews 
    if isAdmin
      a.primary Admin
      a(href="/users") Users
      a(href="/allswaps") All Swaps

      .profile
        h4 Email
        p.email= user.email_address
        h4 Account Created
        p.email= user.created_at
    if loggedIn
      span.nav-spacer
      a.active(href="/profile") Profile
      a(href="/swaps") My Swaps
      a(href="/logout") Logout
    else  
      span.nav-spacer
      a.logonbtn(href="/signin") Sign in
      a.logonbtn.primary(href="/signup") Sign up
  
  .profile
    
    h2= user.username
    

  h3.section-title Recipes

  .card-grid
    each recipe in recipes
      .card
        h4= recipe.recipe_title
        p= recipe.summary
        a.btn(href=`/recipes/${recipe.recipe_id}`) View Recipe

  a.btn(href=`/recipes`) Back to Recipes 